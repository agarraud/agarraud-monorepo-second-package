{
    "name": "agarraud/agarraud-monorepo-second-package",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "symfony/dependency-injection": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Agarraud\\AgarraudMonorepoSecondPackage\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Agarraud\\AgarraudMonorepoSecondPackage\\Tests\\": "tests"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.1-dev"
        }
    }
}
